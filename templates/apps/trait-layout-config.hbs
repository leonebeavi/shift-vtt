<section class="tl-body">
  <p class="hint">{{localize hintKey}}</p>

  <ul class="tl-rows">
    {{#each rows}}
      <li class="tl-row" data-index="{{index}}" data-key="{{key}}"{{#if color}} style="--tl-accent: {{color}};"{{/if}}>
        <div class="tl-head">
          <span class="tl-reorder">
            <a data-action="moveRow" data-dir="up" data-index="{{index}}" data-tooltip="{{localize 'SHIFT.TraitLayout.MoveUp'}}"><i class="fa-solid fa-chevron-up"></i></a>
            <a data-action="moveRow" data-dir="down" data-index="{{index}}" data-tooltip="{{localize 'SHIFT.TraitLayout.MoveDown'}}"><i class="fa-solid fa-chevron-down"></i></a>
          </span>
          <input class="tl-label" type="text" name="label" value="{{label}}" placeholder="{{localize 'SHIFT.TraitLayout.Label'}}"/>
          <a class="tl-del" data-action="deleteRow" data-index="{{index}}" data-tooltip="{{localize 'SHIFT.TraitLayout.Delete'}}"><i class="fa-solid fa-trash"></i></a>
        </div>

        <div class="tl-opts">
          <label class="tl-field" data-tooltip="{{localize 'SHIFT.TraitLayout.Columns'}}">
            <i class="fa-solid fa-table-columns"></i>
            <select name="columns" aria-label="{{localize 'SHIFT.TraitLayout.Columns'}}">
              {{#each columnsOptions}}<option value="{{value}}"{{#if selected}} selected{{/if}}>{{value}}</option>{{/each}}
            </select>
          </label>

          {{#if @root.showCreate}}
            <label class="tl-field" data-tooltip="{{localize 'SHIFT.TraitLayout.DefaultType'}}">
              <i class="fa-solid fa-dice-d20"></i>
              <select name="create" aria-label="{{localize 'SHIFT.TraitLayout.DefaultType'}}">
                {{#each categoryOptions}}<option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}</option>{{/each}}
              </select>
            </label>
          {{/if}}

          <input type="hidden" name="color" value="{{color}}"/>
          <div class="swatch-picker" aria-label="{{localize 'SHIFT.TraitLayout.Color'}}">
            <a class="swatch auto{{#if (shiftEq color '')}} selected{{/if}}" data-action="pickColor" data-color="" data-tooltip="{{localize 'SHIFT.TraitLayout.ColorAuto'}}"></a>
            {{#each @root.palette}}
              <a class="swatch{{#if (shiftEq this ../color)}} selected{{/if}}" style="--sw: {{this}};" data-action="pickColor" data-color="{{this}}" data-tooltip="{{this}}"></a>
            {{/each}}
          </div>
        </div>
      </li>
    {{/each}}
  </ul>

  <div class="tl-bar">
    <div class="tl-actions">
      <a class="ta-btn" data-action="addRow" data-tooltip="{{localize 'SHIFT.TraitLayout.Add'}}"><i class="fa-solid fa-plus"></i></a>
      <a class="ta-btn" data-action="resetDefaults" data-tooltip="{{localize 'SHIFT.TraitLayout.Reset'}}"><i class="fa-solid fa-rotate-left"></i></a>
    </div>
    <footer class="form-footer">
      {{#each buttons}}
        <button type="{{type}}"><i class="{{icon}}"></i> {{localize label}}</button>
      {{/each}}
    </footer>
  </div>
</section>
