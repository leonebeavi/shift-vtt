{{!-- SHIFT VTT — Party header: crest banner + identity + party-wide actions +
      the Location strip + the tab nav (Roster · Traits · Codex · Quests). The nav
      uses class "party-tabs" (NOT "tabs"); ShiftPartySheet overrides `_onClickTab`
      to switch tabs by re-rendering (each section gates on `activeTab`).
      The crest `data-edit="img"` MUST live on the <img> (core form serialization
      reads an IMG's src but a wrapper element's innerHTML — which is invalid). --}}
<div class="sheet-top party-top">
  <header class="party-banner">
    <div class="party-crest">
      <img class="party-crest-img" src="{{actor.img}}" alt="{{actor.name}}"
           data-action="editImage" data-edit="img" data-tooltip="{{localize 'SHIFT.Tooltips.EditImage'}}"/>
    </div>

    <div class="party-id">
      <div class="party-id-top">
        {{#if editMode}}
          <input class="party-title-edit" type="text" name="name" value="{{actor.name}}"
                 placeholder="{{localize 'SHIFT.Sheet.Name'}}"/>
        {{else}}
          <h1 class="party-title">{{actor.name}}</h1>
        {{/if}}
      </div>
      <div class="party-meta">
        <span class="party-chip is-type"><i class="fa-solid fa-people-group"></i> {{localize "TYPES.Actor.party"}}</span>
        <span class="party-chip"><i class="fa-solid fa-user-group"></i> {{memberCount}} {{localize "SHIFT.Party.Members"}}</span>
        <span class="party-chip"><i class="fa-solid fa-book-skull"></i> {{codexCount}} {{localize "SHIFT.Party.Codex.Label"}}</span>
      </div>
    </div>

    {{#if editable}}
      <div class="party-actions stacked">
        <button type="button" class="party-btn pa-xp" data-action="grantPartyXp">
          <i class="fa-solid fa-arrow-trend-up"></i> {{localize "SHIFT.Party.GrantXp"}}
        </button>
        {{#if isGM}}
          <button type="button" class="party-btn pa-roll" data-action="requestPartyRoll">
            <i class="fa-solid fa-dice"></i> {{localize "SHIFT.Party.RequestRoll.Button"}}
          </button>
        {{/if}}
        <button type="button" class="party-btn pa-safe" data-action="partySafeRest"
                data-tooltip="{{localize 'SHIFT.Party.SafeRestHint'}}">
          <i class="fa-solid fa-campground"></i> {{localize "SHIFT.Rest.Safe"}}
        </button>
        <button type="button" class="party-btn pa-unsafe" data-action="partyUnsafeRest">
          <i class="fa-solid fa-fire"></i> {{localize "SHIFT.Rest.Unsafe"}}
        </button>
        {{#if isGM}}{{#if travelEnabled}}{{#unless journey}}
          <button type="button" class="party-btn pa-travel" data-action="travelStart">
            <i class="fa-solid fa-compass"></i> {{localize "SHIFT.Travel.Button"}}
          </button>
        {{/unless}}{{/if}}{{/if}}
      </div>
    {{/if}}
  </header>

  {{!-- Context row: where the party is (Location, drives Rest rules) and its
        active Vehicle (crew mirrors the roster), side by side. --}}
  {{#if (shiftOr locationInfo (shiftOr editMode activeVehicle))}}
    <div class="party-context">
      {{!-- Location --}}
      {{#if locationInfo}}
        <div class="party-location pc-field" data-drop="location">
          <span class="pl-icon"><i class="fa-solid fa-map-location-dot"></i></span>
          {{#if locationInfo.img}}<img class="pl-img" src="{{locationInfo.img}}" alt="{{locationInfo.name}}"
               data-action="openLocation" data-tooltip="{{localize 'SHIFT.Party.OpenLocation'}}"/>{{/if}}
          <div class="pl-body">
            {{#if locationInfo.hasBreadcrumb}}
              <div class="pl-breadcrumb">{{#each locationInfo.breadcrumb}}<span>{{name}}</span>{{#unless @last}} <i class="fa-solid fa-chevron-right"></i> {{/unless}}{{/each}}</div>
            {{/if}}
            <a class="pl-name" data-action="openLocation" data-tooltip="{{localize 'SHIFT.Party.OpenLocation'}}">{{locationInfo.name}}</a>
          </div>
          {{#if (shiftNeq locationInfo.landmarkSafe null)}}
            <span class="pl-safe{{#unless locationInfo.landmarkSafe}} unsafe{{/unless}}"
                  data-tooltip="{{#if locationInfo.landmarkSafe}}{{localize 'SHIFT.Party.Codex.Safe'}}{{else}}{{localize 'SHIFT.Party.Codex.Unsafe'}}{{/if}}">
              <i class="fa-solid {{#if locationInfo.landmarkSafe}}fa-shield-heart{{else}}fa-triangle-exclamation{{/if}}"></i>
            </span>
          {{/if}}
          {{#if editMode}}<a class="pl-clear edit-only" data-action="clearLocation" data-tooltip="{{localize 'SHIFT.Party.ClearLocation'}}"><i class="fa-solid fa-xmark"></i></a>{{/if}}
        </div>
      {{else if editMode}}
        <div class="party-location pc-field empty edit-only" data-drop="location">
          <i class="fa-solid fa-map-location-dot"></i> {{localize "SHIFT.Party.DropLocation"}}
        </div>
      {{/if}}

      {{!-- Active Vehicle (crew auto-mirrors the roster) --}}
      {{#if activeVehicle}}
        <div class="roster-vehicle pc-field" data-drop="vehicle">
          <span class="rv-icon"><i class="fa-solid fa-car-side"></i></span>
          {{#if activeVehicle.img}}<img class="rv-img" src="{{activeVehicle.img}}" alt="{{activeVehicle.name}}"
               data-action="openVehicle" data-tooltip="{{localize 'SHIFT.Party.OpenVehicle'}}"/>{{/if}}
          <div class="rv-body">
            <span class="rv-label">{{localize "SHIFT.Party.ActiveVehicle"}}</span>
            <a class="rv-name" data-action="openVehicle" data-tooltip="{{localize 'SHIFT.Party.OpenVehicle'}}">{{activeVehicle.name}}</a>
          </div>
          <span class="rv-crew" data-tooltip="{{localize 'SHIFT.Party.Codex.Crew'}}"><i class="fa-solid fa-users"></i> {{activeVehicle.crewCount}}</span>
          {{#if editMode}}<a class="rv-clear edit-only" data-action="clearVehicle" data-tooltip="{{localize 'SHIFT.Party.ClearVehicle'}}"><i class="fa-solid fa-xmark"></i></a>{{/if}}
        </div>
      {{else if editMode}}
        <div class="roster-vehicle pc-field empty edit-only" data-drop="vehicle">
          <i class="fa-solid fa-car-side"></i> {{localize "SHIFT.Party.DropVehicle"}}
        </div>
      {{/if}}
    </div>
  {{/if}}

  {{!-- Faixa de jornada de Travel (subsistema opcional): destino + Legs em
        bolinhas + modo; controles (Avançar/Chegar/Abortar) só para o GM, que
        conduz a viagem. Os players veem o progresso. --}}
  {{#if journey}}
    <div class="party-journey{{#if journey.complete}} complete{{/if}}{{#if journey.simple}} simple{{/if}}">
      <span class="pj-icon"><i class="fa-solid fa-route"></i></span>
      <div class="pj-body">
        <div class="pj-top">
          <span class="pj-dest">{{journey.destName}}</span>
          {{#if journey.modeLabel}}<span class="pj-mode">{{journey.modeLabel}}</span>{{/if}}
          <span class="pj-transport" data-tooltip="{{#if journey.onFoot}}{{localize 'SHIFT.Travel.OnFoot'}}{{else}}{{localize 'SHIFT.Travel.ByVehicle'}}{{/if}}">
            <i class="fa-solid {{#if journey.onFoot}}fa-person-walking{{else}}fa-truck-fast{{/if}}"></i>
          </span>
        </div>
        {{#if journey.flavor}}<div class="pj-flavor">{{journey.flavor}}</div>{{/if}}
        {{#unless journey.simple}}
          <div class="pj-legs">
            {{#each journey.dots}}<span class="pj-dot{{#if done}} done{{/if}}"></span>{{/each}}
            <span class="pj-count">{{localize "SHIFT.Travel.Legs"}} {{journey.legsDone}} / {{journey.legsTotal}}</span>
          </div>
        {{/unless}}
      </div>
      {{#if isGM}}
        <div class="pj-actions">
          {{#if journey.simple}}
            <a class="pj-btn arrive ready" data-action="travelFinish" data-tooltip="{{localize 'SHIFT.Travel.Finish'}}"><i class="fa-solid fa-flag-checkered"></i></a>
          {{else}}
            {{#unless journey.complete}}
              <a class="pj-btn advance" data-action="travelAdvance" data-tooltip="{{localize 'SHIFT.Travel.Advance'}}"><i class="fa-solid fa-person-hiking"></i></a>
            {{/unless}}
            <a class="pj-btn arrive{{#if journey.complete}} ready{{/if}}" data-action="travelArrive" data-tooltip="{{localize 'SHIFT.Travel.Arrive'}}"><i class="fa-solid fa-flag-checkered"></i></a>
          {{/if}}
          <a class="pj-btn abort" data-action="travelAbort" data-tooltip="{{localize 'SHIFT.Travel.Abort'}}"><i class="fa-solid fa-xmark"></i></a>
        </div>
      {{/if}}
    </div>
  {{/if}}

  <nav class="party-tabs">
    {{#each tabs}}
      <a class="party-tab{{#if (shiftEq @root.activeTab id)}} active{{/if}}"
         data-action="tab" data-group="primary" data-tab="{{id}}">
        <i class="fa-solid {{icon}}"></i> {{localize label}}
        {{#if badge}}<span class="tab-badge">{{badge}}</span>{{/if}}
      </a>
    {{/each}}
    {{#if editable}}
      <span class="tab-tools">
        {{#if editMode}}
          {{#if (shiftEq activeTab 'codex')}}{{#if codexCount}}
            <a class="party-tab-tool reveal-all" data-action="revealAllCodex" data-tooltip="{{localize 'SHIFT.Party.Codex.RevealAll'}}">
              <i class="fa-solid fa-eye"></i>
            </a>
            <a class="party-tab-tool hide-all" data-action="hideAllCodex" data-tooltip="{{localize 'SHIFT.Party.Codex.HideAll'}}">
              <i class="fa-solid fa-eye-slash"></i>
            </a>
          {{/if}}{{/if}}
          <a class="party-tab-tool recharge" data-action="rechargeAll" data-tooltip="{{localize 'SHIFT.Tooltips.RechargeAll'}}">
            <i class="fa-solid fa-arrows-rotate"></i>
          </a>
        {{/if}}
        <a class="party-tab-tool{{#if editMode}} active{{/if}}" data-action="toggleEdit">
          <i class="fa-solid {{#if editMode}}fa-lock-open{{else}}fa-lock{{/if}}"></i>
        </a>
      </span>
    {{/if}}
  </nav>
</div>
