<section class="tab npcs{{#if (shiftEq activeTab 'npcs')}} active{{/if}}" data-tab="npcs" data-group="primary">
  <div class="trait-group" data-group-key="npcs">
    <header class="group-header">
      <h2>{{localize "SHIFT.Location.NPCs"}}</h2>
    </header>

    <div class="npc-grid">
      {{#each npcs}}
        <div class="npc-card" data-npc-uuid="{{uuid}}">
          <img class="npc-img" src="{{img}}" alt="{{name}}" data-action="openNpc"
               data-tooltip="{{localize 'SHIFT.Location.OpenNpc'}}"/>
          <div class="npc-main">
            <a class="npc-name" data-action="openNpc">{{name}}</a>
            <span class="npc-type">{{typeLabel}}</span>
          </div>
          {{#if @root.editMode}}
            <a class="ta-btn danger npc-remove" data-action="removeNpc"
               data-tooltip="{{localize 'SHIFT.Tooltips.Delete'}}"><i class="fa-solid fa-xmark"></i></a>
          {{/if}}
        </div>
      {{/each}}
      {{#unless npcs.length}}
        <p class="empty npc-empty"><i class="fa-solid fa-hand-pointer"></i> {{localize "SHIFT.Location.NPCsHint"}}</p>
      {{/unless}}
    </div>
  </div>
</section>
