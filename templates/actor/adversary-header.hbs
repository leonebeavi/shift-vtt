{{!-- SHIFT VTT — Adversary header (REDESIGN v2)
     Substitui templates/actor/adversary-header.hbs
     Identidade enxuta (nome + conceito); stats reorganizados NA LATERAL
     (chips de vidro com valor à direita) + medidor Overcome; Action Roll
     ancorado no rodapé do header. --}}
<div class="sheet-top adversary-top">
  <header class="sheet-header adversary-header">

    <div class="portrait">
      <img class="portrait-img" src="{{actor.img}}" alt="{{actor.name}}" data-action="editImage" data-edit="img"
           data-tooltip="{{localize 'SHIFT.Tooltips.EditImage'}}"/>
      {{#if enableScale}}
        <span class="scale-badge" data-scale="{{system.scale}}"
              {{#if editMode}}data-action="cycleScale"{{/if}}
              data-tooltip="{{localize 'SHIFT.Trait.Scale'}} {{system.scale}}">{{system.scale}}</span>
      {{/if}}
    </div>

    <div class="header-main">
      <div class="identity">
        <input class="char-name" type="text" name="name" value="{{actor.name}}"
               placeholder="{{localize 'SHIFT.Sheet.Name'}}" {{#unless editMode}}disabled{{/unless}}/>
        {{#if editMode}}
          <textarea class="char-concept" name="system.concept" rows="1"
                    placeholder="{{localize 'SHIFT.Sheet.Concept'}}">{{system.concept}}</textarea>
        {{else}}
          {{#if (shiftAnd system.concept canViewNotes)}}<div class="char-concept-text">{{system.concept}}</div>{{/if}}
        {{/if}}
      </div>
    </div>

    <div class="header-side">
      <span class="type-badge"><i class="fa-solid fa-skull"></i> {{localize "TYPES.Actor.adversary"}}</span>

      {{#if editable}}
        <div class="header-actions">
          <button type="button" class="shift-btn primary" data-action="actionRoll">
            <i class="fa-solid fa-dice"></i> {{localize "SHIFT.Roll.ActionRoll"}}
          </button>
        </div>
      {{/if}}

      <div class="defeat-widget{{#if derived.overcome}} overcome{{/if}}" data-tooltip="{{localize 'SHIFT.Tooltips.Defeat'}}">
        <div class="defeat-top">
          <span class="defeat-label">{{localize "SHIFT.Adversary.Defeat"}}</span>
          <span class="defeat-count">{{derived.defeat.value}} / {{derived.defeat.max}}</span>
        </div>
        <div class="defeat-bar"><div class="defeat-fill" style="width: {{derived.defeatPct}}%"></div></div>
      </div>

      <div class="header-stats">
        {{#if editMode}}
          <label class="power-field" data-tooltip="{{localize 'SHIFT.Tooltips.Power'}}">
            <i class="fa-solid fa-fire"></i>
            <input type="number" name="system.power" value="{{system.power}}" min="1" step="1"/>
          </label>
        {{else}}
          <span class="stat-pill power" data-tooltip="{{localize 'SHIFT.Adversary.Power'}}"><i class="fa-solid fa-fire"></i> <b class="pv">{{system.power}}</b></span>
        {{/if}}
        <span class="adv-stat" data-tooltip="{{localize 'SHIFT.Adversary.Actions'}}"><i class="fa-solid fa-bolt"></i> <b class="pv">{{derived.actions}}</b></span>
        <span class="adv-stat" data-tooltip="{{localize 'SHIFT.Tooltips.TraitBudget'}}"><i class="fa-solid fa-layer-group"></i> <b class="pv">{{derived.traitCount}}/{{derived.traitLimit}}</b></span>
      </div>
    </div>
  </header>

  {{#if derived.overcome}}
    <div class="overcome-banner">
      <i class="fa-solid fa-flag-checkered"></i> {{localize "SHIFT.Adversary.Overcome"}}
    </div>
  {{/if}}
  {{#if derived.blockedBy.length}}
    <div class="blocked-banner">
      <i class="fa-solid fa-lock"></i> {{localize "SHIFT.Adversary.BlockedBy"}}
      {{#each derived.blockedBy}}<b>{{this}}</b>{{#unless @last}}, {{/unless}}{{/each}}
    </div>
  {{/if}}

  <nav class="sheet-tabs tabs" data-group="primary">
    {{#each tabs}}
      <a class="tab-link{{#if (shiftEq @root.activeTab id)}} active{{/if}}"
         data-action="tab" data-group="primary" data-tab="{{id}}">
        <i class="fa-solid {{icon}}"></i> {{localize label}}
      </a>
    {{/each}}
    {{#if editable}}
      <span class="tab-tools">
        {{#if editMode}}
          <a class="tab-tool recharge" data-action="rechargeAll" data-tooltip="{{localize 'SHIFT.Tooltips.RechargeAll'}}">
            <i class="fa-solid fa-arrows-rotate"></i>
          </a>
        {{/if}}
        <a class="tab-tool{{#if editMode}} active{{/if}}" data-action="toggleEdit" data-tooltip="{{localize 'SHIFT.Tooltips.EditToggle'}}">
          <i class="fa-solid {{#if editMode}}fa-lock-open{{else}}fa-lock{{/if}}"></i>
        </a>
      </span>
    {{/if}}
  </nav>
</div>
