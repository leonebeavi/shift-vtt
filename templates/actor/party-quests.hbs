{{!-- SHIFT VTT — Quests tab. A Quest é um tipo de Item PRÓPRIO (type "quest",
      ShiftQuestData): o die é seu clock (rollable opcional, shifts up/down,
      exhausts), com desfecho Success/Failure independente (system.outcome) e
      links de Actors/Items (system.links). O GM oculta dos players pelo olho
      (system.revealed). Cards renderizam via o partial shift.ptrait-card (com
      quest=true); arraste um card sobre outro para reordenar, ou um Actor/Item
      sobre o card para vincular. --}}
<section class="party-page quests{{#if (shiftEq activeTab 'quests')}} active{{/if}}"
         data-page="quests" data-tab="quests" data-group="primary">
  <div class="party-quests party-traits-page">
    {{#if @root.editMode}}
      <div class="pt-toolbar">
        <a class="party-btn pt-add" data-action="createItem" data-type="quest">
          <i class="fa-solid fa-plus"></i> {{localize "SHIFT.Party.Quests.Add"}}
        </a>
      </div>
    {{/if}}

    <div class="ptrait-grid">
      {{#each questGroup.traits}}
        <div class="pt-quest-row{{#if this.depth}} is-child{{/if}}{{#if this.firstSub}} is-first-sub{{/if}}" style="--depth: {{this.depth}};">
          {{> "shift.ptrait-card" this showHide=true quest=true}}
        </div>
      {{/each}}
      {{#unless questGroup.traits.length}}
        <div class="party-empty"><i class="fa-solid fa-scroll"></i><p>{{localize "SHIFT.Party.Quests.Empty"}}</p></div>
      {{/unless}}
    </div>
  </div>
</section>
