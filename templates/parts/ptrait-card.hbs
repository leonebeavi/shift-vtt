{{!-- SHIFT VTT — one rich ".ptrait" trait card (die · name · status·max ·
      description · Keyword/Drawback pills · tools). Shared by the party Traits
      tab and the Quests tab (a Quest IS a Trait of category "quest"). Context =
      a trait tile object; pass showHide=true to add the GM "hide from players"
      toggle (the Trait's `revealed` flag) — used on the Quests tab. --}}
<div class="ptrait status-{{statusKey}}{{#if exhausted}} is-exhausted{{/if}}{{#if hidden}} is-gmhidden{{/if}}"
     data-item-id="{{id}}" data-draggable="true">
  <div class="ptrait-head">
    {{#if canRoll}}
      <a class="ptrait-die" data-action="rollTrait"
         data-tooltip="{{statusLabel}} &middot; {{localize 'SHIFT.Tooltips.RollIcon'}}">
        {{#if dieImg}}<img src="{{dieImg}}" alt="{{currentLabel}}"/>{{else}}<i class="fa-solid fa-ban"></i>{{/if}}
      </a>
    {{else}}
      <span class="ptrait-die" data-tooltip="{{statusLabel}}">{{#if dieImg}}<img src="{{dieImg}}" alt="{{currentLabel}}"/>{{else}}<i class="fa-solid fa-ban"></i>{{/if}}</span>
    {{/if}}
    <div class="ptrait-title">
      {{#if @root.editMode}}<a class="ptrait-name" data-action="editItem">{{name}}</a>{{else}}<span class="ptrait-name">{{name}}</span>{{/if}}
      <span class="ptrait-sub"><b>{{statusLabel}}</b> &middot; {{localize "SHIFT.Trait.Max"}} {{maxLabel}}</span>
    </div>
    {{#if @root.editable}}
      <div class="ptrait-tools">
        {{#if showHide}}{{#if @root.isGM}}
          <a class="ta-btn hide{{#if hidden}} on{{/if}}" data-action="toggleTraitHide"
             data-tooltip="{{localize 'SHIFT.Party.HideToggle'}}"><i class="fa-solid {{#if hidden}}fa-eye-slash{{else}}fa-eye{{/if}}"></i></a>
        {{/if}}{{/if}}
        <a class="ta-btn up{{#unless canUp}} disabled{{/unless}}" data-action="shiftUp" data-tooltip="{{localize 'SHIFT.Tooltips.ShiftUp'}}"><i class="fa-solid fa-circle-arrow-up"></i></a>
        <a class="ta-btn down{{#unless canDown}} disabled{{/unless}}" data-action="shiftDown" data-tooltip="{{localize 'SHIFT.Tooltips.ShiftDown'}}"><i class="fa-solid fa-circle-arrow-down"></i></a>
        {{#if @root.editMode}}
          <a class="ta-btn edit" data-action="editItem" data-tooltip="{{localize 'SHIFT.Tooltips.Edit'}}"><i class="fa-solid fa-pen-to-square"></i></a>
          <a class="ta-btn danger" data-action="deleteItem" data-tooltip="{{localize 'SHIFT.Tooltips.Delete'}}"><i class="fa-solid fa-trash"></i></a>
        {{/if}}
      </div>
    {{/if}}
  </div>

  {{#if desc}}<div class="ptrait-desc">{{{desc}}}</div>{{/if}}

  {{#if (shiftOr usesKeywords usesDrawbacks)}}
    <div class="ptrait-pills">
      {{#if usesKeywords}}
        {{> "shift.pill-list" items=keywords kind="keyword"
            label=(localize "SHIFT.Keywords.Title")
            addAction="addKeyword" removeAction="removeKeyword"
            canEdit=@root.editMode addTooltip=(localize "SHIFT.Keywords.Add")}}
      {{/if}}
      {{#if usesDrawbacks}}
        {{#if (shiftOr drawbacks.length @root.editMode)}}
          {{> "shift.pill-list" items=drawbacks kind="drawback"
              label=(localize "SHIFT.Drawbacks.Title")
              addAction="addDrawback" removeAction="removeDrawback"
              canEdit=@root.editMode addTooltip=(localize "SHIFT.Drawbacks.Add")}}
        {{/if}}
      {{/if}}
    </div>
  {{/if}}
</div>
