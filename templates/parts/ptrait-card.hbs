{{!-- SHIFT VTT — one rich ".ptrait" card (die · name · status·max · description ·
      tools). Shared by the party Traits tab and the Quests tab. Pass showHide=true
      to add the GM "hide from players" toggle. Pass quest=true (Quests tab) to turn
      on the quest-only blocks (outcome state + Resolve/Fail/Reopen + links) — they
      stay guarded by {{#if quest}} so the Traits tab is never touched. --}}
<div class="ptrait status-{{statusKey}}{{#if exhausted}} is-exhausted{{/if}}{{#if quest}} is-quest{{#unless expanded}} is-collapsed{{/unless}}{{#if resolved}} outcome-{{outcome}}{{/if}}{{#if locked}} is-locked{{/if}}{{/if}}{{#if hidden}} is-gmhidden{{/if}}"
     data-item-id="{{id}}" data-draggable="true"{{#if quest}} data-action="toggleQuestBody"{{/if}}>
  <div class="ptrait-head">
    {{#if (shiftAnd quest resolved)}}
      <span class="ptrait-state" data-tooltip="{{outcomeWord}}"><i class="fa-solid {{outcomeIcon}}"></i></span>
    {{else if canRoll}}
      <a class="ptrait-die" data-action="{{#if quest}}rollQuest{{else}}rollTrait{{/if}}"
         data-tooltip="{{statusLabel}} &middot; {{localize 'SHIFT.Tooltips.RollIcon'}}">
        {{#if dieImg}}<img src="{{dieImg}}" alt="{{currentLabel}}"/>{{else}}<i class="fa-solid fa-ban"></i>{{/if}}
      </a>
    {{else}}
      <span class="ptrait-die" data-tooltip="{{statusLabel}}">{{#if dieImg}}<img src="{{dieImg}}" alt="{{currentLabel}}"/>{{else}}<i class="fa-solid fa-ban"></i>{{/if}}</span>
    {{/if}}
    <div class="ptrait-title">
      <span class="ptrait-namerow">
        {{#if @root.editMode}}<a class="ptrait-name" data-action="editItem">{{name}}</a>{{else}}<span class="ptrait-name">{{name}}</span>{{/if}}
        {{#if (shiftAnd quest hasChildren)}}<a class="pt-progress{{#if (shiftEq progressDone progressTotal)}} full{{/if}}" data-action="toggleQuestKids" data-tooltip="{{localize 'SHIFT.Party.Quests.Subquests'}}"><i class="fa-solid {{#if kidsCollapsed}}fa-chevron-right{{else}}fa-chevron-down{{/if}}"></i> {{progressDone}}/{{progressTotal}}</a>{{/if}}
      </span>
      {{#if (shiftAnd quest resolved)}}
        <span class="ptrait-sub"><b>{{outcomeWord}}</b> &middot; {{localize "SHIFT.Party.Quests.Resolved"}}</span>
      {{else if (shiftAnd quest locked)}}
        <span class="ptrait-sub locked">
          <span class="lk-badge"><i class="fa-solid fa-lock"></i></span>
          <span class="lk-label">{{localize "SHIFT.Party.Quests.Requires"}}</span>
          {{#each requiresPending}}<span class="lk-pill">{{this}}</span>{{/each}}
        </span>
      {{else}}
        <span class="ptrait-sub"><b>{{statusLabel}}</b> &middot; {{localize "SHIFT.Trait.Max"}} {{maxLabel}}</span>
      {{/if}}
    </div>
    {{#if @root.editable}}
      <div class="ptrait-tools">
        {{#if showHide}}{{#if @root.isGM}}
          <a class="ta-btn hide{{#if hidden}} on{{/if}}" data-action="toggleTraitHide"
             data-tooltip="{{localize 'SHIFT.Party.HideToggle'}}"><i class="fa-solid {{#if hidden}}fa-eye-slash{{else}}fa-eye{{/if}}"></i></a>
        {{/if}}{{/if}}
        <a class="ta-btn up{{#unless canUp}} disabled{{/unless}}" data-action="shiftUp" data-tooltip="{{localize 'SHIFT.Tooltips.ShiftUp'}}"><i class="fa-solid fa-circle-arrow-up"></i></a>
        <a class="ta-btn down{{#unless canDown}} disabled{{/unless}}" data-action="shiftDown" data-tooltip="{{localize 'SHIFT.Tooltips.ShiftDown'}}"><i class="fa-solid fa-circle-arrow-down"></i></a>
        {{#if @root.editMode}}
          <a class="ta-btn edit" data-action="editItem" data-tooltip="{{localize 'SHIFT.Tooltips.Edit'}}"><i class="fa-solid fa-pen-to-square"></i></a>
          <a class="ta-btn danger" data-action="deleteItem" data-tooltip="{{localize 'SHIFT.Tooltips.Delete'}}"><i class="fa-solid fa-trash"></i></a>
        {{/if}}
      </div>
    {{/if}}
  </div>

  {{!-- Descrição: nos Traits sempre; nas Quests só quando expandida (compacta esconde). --}}
  {{#if desc}}{{#if (shiftOr expanded (shiftNeq quest true))}}<div class="ptrait-desc">{{{desc}}}</div>{{/if}}{{/if}}

  {{#if (shiftOr usesKeywords usesDrawbacks)}}
    <div class="ptrait-pills">
      {{#if usesKeywords}}
        {{> "shift.pill-list" items=keywords kind="keyword"
            label=(localize "SHIFT.Keywords.Title")
            addAction="addKeyword" removeAction="removeKeyword"
            canEdit=@root.editMode addTooltip=(localize "SHIFT.Keywords.Add")}}
      {{/if}}
      {{#if usesDrawbacks}}
        {{#if (shiftOr drawbacks.length @root.editMode)}}
          {{> "shift.pill-list" items=drawbacks kind="drawback"
              label=(localize "SHIFT.Drawbacks.Title")
              addAction="addDrawback" removeAction="removeDrawback"
              canEdit=@root.editMode addTooltip=(localize "SHIFT.Drawbacks.Add")}}
        {{/if}}
      {{/if}}
    </div>
  {{/if}}

  {{!-- Quest footer: links à esquerda + desfecho Resolve/Fail/Reopen à direita. O
        rodapé aparece quando há links OU para quem edita. Drop de Actor/Item sobre o
        card cria o link (#questDropTarget casa com .party-quests .ptrait[data-item-id]). --}}
  {{#if quest}}{{#if showFoot}}
    <div class="pt-foot">
      {{!-- Links só quando EXPANDIDA (compacta esconde). Sem links, a seção some. --}}
      {{#if (shiftAnd expanded links.length)}}
        <div class="pt-links">
          <span class="label">{{localize "SHIFT.Party.Quests.Field.Links"}}</span>
          {{#each links}}
            <a class="pt-link" style="--lc: {{this.color}};" data-link-uuid="{{this.uuid}}" data-action="openQuestLink" data-tooltip="{{this.name}}">
              <i class="fa-solid {{this.icon}}"></i>
              {{#if @root.editMode}}<i class="pt-link-x fa-solid fa-xmark" data-action="removeQuestLink" data-tooltip="{{localize 'SHIFT.Party.Quests.RemoveLink'}}"></i>{{/if}}
            </a>
          {{/each}}
          {{#if @root.editMode}}
            <span class="pt-link-hint" data-tooltip="{{localize 'SHIFT.Party.Quests.LinkHint'}}"><i class="fa-solid fa-plus"></i></span>
          {{/if}}
        </div>
      {{/if}}
      {{#if @root.editable}}
        <div class="pt-outcome">
          {{#if canResolve}}<a class="resolve" data-action="questResolve" data-tooltip="{{localize 'SHIFT.Party.Quests.Complete'}}"><i class="fa-solid fa-check"></i></a>{{/if}}
          {{#if canFail}}<a class="fail" data-action="questFail" data-tooltip="{{localize 'SHIFT.Party.Quests.Fail'}}"><i class="fa-solid fa-xmark"></i></a>{{/if}}
          {{#if canReopen}}<a class="reopen" data-action="questReopen" data-tooltip="{{localize 'SHIFT.Party.Quests.Reopen'}}"><i class="fa-solid fa-rotate-left"></i></a>{{/if}}
        </div>
      {{/if}}
    </div>
  {{/if}}{{/if}}
</div>
