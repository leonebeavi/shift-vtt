{{!-- Trait item sheet. Header + die-hero, then two internal tabs (Description /
      Customize). An owner sees the lock toggle; locked shows the observer
      (player) view — editing inputs become read-only and the Customize tab hides. --}}
<div class="item-sheet trait-sheet minimal">
  <header class="item-header">
    <img class="item-img" src="{{item.img}}" alt="{{item.name}}" data-action="editImage" data-edit="img"/>
    <div class="item-id">
      <input class="item-name" type="text" name="name" value="{{item.name}}" {{#unless editMode}}disabled{{/unless}}/>
      <div class="item-subline">
        {{#if editable}}
          <a class="item-lock{{#if editMode}} active{{/if}}" data-action="toggleEdit" data-tooltip="{{localize 'SHIFT.Tooltips.EditToggle'}}">
            <i class="fa-solid {{#if editMode}}fa-lock-open{{else}}fa-lock{{/if}}"></i>
          </a>
        {{/if}}
        <span class="category-pill">{{categoryLabel}}</span>
        {{#if showScaleTag}}
          <span class="scale-pip inline" data-scale="{{effectiveScale}}" data-tooltip="{{scaleTooltip}}">{{effectiveScale}}</span>
        {{/if}}
        {{#if system.temporary}}<span class="tag temporary" data-tooltip="{{localize 'SHIFT.Tooltips.Temporary'}}"><i class="fa-solid fa-hourglass-half"></i></span>{{/if}}
      </div>
    </div>
  </header>

  <section class="die-hero status-{{statusKey}}">
    {{#if dieImg}}
      {{#if editable}}
        <a class="die-badge img hero" data-die="{{statusKey}}" data-action="rollTrait"
           data-tooltip="{{statusLabel}}">
          <img src="{{dieImg}}" alt="{{currentLabel}}"/>
        </a>
      {{else}}
        {{!-- View-only: a non-owner sees the die status but cannot roll. --}}
        <span class="die-badge img hero" data-die="{{statusKey}}" data-tooltip="{{statusLabel}}">
          <img src="{{dieImg}}" alt="{{currentLabel}}"/>
        </span>
      {{/if}}
    {{else}}
      <span class="die-badge exhausted-x hero" data-tooltip="{{statusLabel}}"><i class="fa-solid fa-xmark"></i></span>
    {{/if}}
    <div class="die-meta">
      <span class="die-status">{{statusLabel}}</span>
      <span class="die-max">{{localize "SHIFT.Trait.Max"}} {{maxLabel}}</span>
    </div>
    {{#if editable}}
      <div class="die-controls">
        <a class="ta-btn up{{#unless canShiftUp}} disabled{{/unless}}" data-action="shiftUp" data-tooltip="{{localize 'SHIFT.Tooltips.ShiftUp'}}"><i class="fa-solid fa-circle-arrow-up"></i></a>
        <a class="ta-btn down{{#unless canShiftDown}} disabled{{/unless}}" data-action="shiftDown" data-tooltip="{{localize 'SHIFT.Tooltips.ShiftDown'}}"><i class="fa-solid fa-circle-arrow-down"></i></a>
        {{#unless system.exhausted}}
          <a class="ta-btn exhaust" data-action="exhaustTrait" data-tooltip="{{localize 'SHIFT.Tooltips.Exhaust'}}"><i class="fa-solid fa-skull"></i></a>
        {{/unless}}
        {{#if canTransform}}
          <a class="ta-btn transform" data-action="transformTrait" data-tooltip="{{localize 'SHIFT.Tooltips.Transform'}}"><i class="fa-solid fa-wand-magic-sparkles"></i></a>
        {{/if}}
      </div>
    {{/if}}
  </section>

  {{!-- Tabs: Description | Customize (editMode) | Transform (GM, ou player-owner se visível). --}}
  {{#if (shiftOr editMode canViewTransform)}}
    <nav class="item-tabs">
      <a class="item-tab{{#if (shiftEq activeTab 'desc')}} active{{/if}}" data-action="itemTab" data-tab="desc"><i class="fa-solid fa-align-left"></i> {{localize "SHIFT.ItemSheet.TabDescription"}}</a>
      {{#if editMode}}
        <a class="item-tab{{#if (shiftEq activeTab 'custom')}} active{{/if}}" data-action="itemTab" data-tab="custom"><i class="fa-solid fa-sliders"></i> {{localize "SHIFT.ItemSheet.TabCustomize"}}</a>
      {{/if}}
      {{#if canViewTransform}}
        <a class="item-tab{{#if (shiftEq activeTab 'transform')}} active{{/if}}" data-action="itemTab" data-tab="transform"><i class="fa-solid fa-wand-magic-sparkles"></i> {{localize "SHIFT.Transform.Tab"}}</a>
      {{/if}}
    </nav>
  {{/if}}

  {{!-- TAB: Description --}}
  <div class="item-tab-panel{{#if (shiftEq activeTab 'desc')}} active{{/if}}" data-tab="desc">
    {{#if system.features.usesKeywords}}
      {{#if (shiftOr system.keywords.length editMode)}}
        {{> "shift.pill-list" items=system.keywords kind="keyword"
            label=(localize "SHIFT.Keywords.Title")
            addAction="addKeyword" removeAction="removeKeyword"
            canEdit=canEditPills addTooltip=(localize "SHIFT.Keywords.Add")}}
      {{/if}}
    {{/if}}
    {{#if system.features.usesDrawbacks}}
      {{#if (shiftOr system.drawbacks.length editMode)}}
        {{> "shift.pill-list" items=system.drawbacks kind="drawback"
            label=(localize "SHIFT.Drawbacks.Title")
            addAction="addDrawback" removeAction="removeDrawback"
            canEdit=canEditPills addTooltip=(localize "SHIFT.Drawbacks.Add")}}
      {{/if}}
    {{/if}}
    {{#if isPackLike}}
      {{#if (shiftOr system.loadout editMode)}}
        <div class="loadout-row sheet">
          <span class="pill-label">{{localize "SHIFT.Sheet.Loadout"}}</span>
          {{#if editMode}}
            <textarea name="system.loadout" rows="1" placeholder="{{localize 'SHIFT.Sheet.LoadoutPlaceholder'}}">{{system.loadout}}</textarea>
          {{else}}
            <span class="loadout-text">{{system.loadout}}</span>
          {{/if}}
        </div>
      {{/if}}
    {{/if}}
    {{#if (shiftOr enrichedDescription editMode)}}
      <section class="item-description">
        {{#if editMode}}
          <prose-mirror name="system.description" value="{{source.description}}" toggled
                        document-uuid="{{item.uuid}}" class="bio-prose">
            {{{enrichedDescription}}}
          </prose-mirror>
        {{else}}
          <div class="bio-display">{{{enrichedDescription}}}</div>
        {{/if}}
      </section>
    {{/if}}
  </div>

  {{!-- TAB: Customize (edit mode only) — one dense panel. --}}
  {{#if editMode}}
  <div class="item-tab-panel{{#if (shiftEq activeTab 'custom')}} active{{/if}}" data-tab="custom">
    <section class="cfg-dense">
      <div class="config-grid">

        <span class="cfg-group-label">{{localize "SHIFT.ItemSheet.DiceConfig"}}</span>
        <label class="cfg">
          <span>{{localize "SHIFT.ItemSheet.MaxDie"}}</span>
          <select name="system.maxDie">
            {{#each diceList}}<option value="{{this}}" {{#if (shiftEq this @root.system.maxDie)}}selected{{/if}}>{{shiftDieLabel this}}</option>{{/each}}
          </select>
        </label>
        <label class="cfg">
          <span>{{localize "SHIFT.ItemSheet.CurrentDie"}}</span>
          {{!-- Disabled while Exhausted: the die is stored separately from the
                exhausted flag; editing here desyncs it. Recover via shift-up. --}}
          <select name="system.currentDie" {{#if system.exhausted}}disabled data-tooltip="{{statusLabel}}"{{/if}}>
            {{#each diceList}}<option value="{{this}}" {{#if (shiftEq this @root.system.currentDie)}}selected{{/if}}>{{shiftDieLabel this}}</option>{{/each}}
          </select>
        </label>
        <label class="cfg">
          <span>{{localize "SHIFT.ItemSheet.Category"}}</span>
          <select name="system.category">
            {{#each categories}}<option value="{{key}}" {{#if (shiftEq key @root.system.category)}}selected{{/if}}>{{label}}</option>{{/each}}
          </select>
        </label>
        <label class="cfg check"><input type="checkbox" name="system.rollable" {{checked system.rollable}}/> {{localize "SHIFT.ItemSheet.Rollable"}}</label>
        <label class="cfg check"><input type="checkbox" name="system.autoShiftOnRoll" {{checked system.autoShiftOnRoll}}/> {{localize "SHIFT.ItemSheet.AutoShift"}}</label>
        <label class="cfg check"><input type="checkbox" name="system.temporary" {{checked system.temporary}}/> {{localize "SHIFT.ItemSheet.Temporary"}}</label>
        <label class="cfg check"><input type="checkbox" name="system.features.usesKeywords" {{checked system.features.usesKeywords}}/> {{localize "SHIFT.Keywords.Title"}}</label>
        <label class="cfg check span2"><input type="checkbox" name="system.features.usesDrawbacks" {{checked system.features.usesDrawbacks}}/> {{localize "SHIFT.Drawbacks.Title"}}</label>

        {{#if enableScale}}
          <span class="cfg-group-label">{{localize "SHIFT.ItemSheet.ScaleConfig"}}</span>
          <label class="cfg check"><input type="checkbox" name="system.scale.custom" {{checked system.scale.custom}}/> {{localize "SHIFT.ItemSheet.ScaleOverride"}}</label>
          <label class="cfg">
            <span>{{localize "SHIFT.Trait.Scale"}}</span>
            <select name="system.scale.value">
              {{#each scaleOptions}}<option value="{{this}}" {{#if (shiftEq this @root.system.scale.value)}}selected{{/if}}>{{this}}</option>{{/each}}
            </select>
          </label>
        {{/if}}

        <span class="cfg-group-label">{{localize "SHIFT.ItemSheet.EncounterConfig"}}</span>
        <label class="cfg check"><input type="checkbox" name="system.defeat.counts" {{checked system.defeat.counts}}/> {{localize "SHIFT.ItemSheet.DefeatCounts"}}</label>
        <label class="cfg check"><input type="checkbox" name="system.defeat.mustBeExhaustedFirst" {{checked system.defeat.mustBeExhaustedFirst}}/> {{localize "SHIFT.ItemSheet.MustFirst"}}</label>
        <label class="cfg">
          <span>{{localize "SHIFT.ItemSheet.ExtraRequired"}}</span>
          <input type="number" name="system.defeat.extraRequired" value="{{system.defeat.extraRequired}}" min="0" step="1"/>
        </label>
        <label class="cfg">
          <span>{{localize "SHIFT.ItemSheet.ExtraActions"}}</span>
          <input type="number" name="system.adversary.extraActions" value="{{system.adversary.extraActions}}" min="0" step="1"/>
        </label>
        <label class="cfg check span2"><input type="checkbox" name="system.adversary.countsTowardTraitLimit" {{checked system.adversary.countsTowardTraitLimit}}/> {{localize "SHIFT.ItemSheet.CountsLimit"}}</label>

      </div>
    </section>
  </div>
  {{/if}}

  {{!-- TAB: Transform — fila de formas linkadas. Edição só do GM (canEditTransform); um
        player-owner com playerVisible vê a lista só-leitura. --}}
  {{#if canViewTransform}}
  <div class="item-tab-panel{{#if (shiftEq activeTab 'transform')}} active{{/if}}" data-tab="transform">
    <section class="transform-panel{{#unless canEditTransform}} readonly{{/unless}}">

      {{#if canEditTransform}}
        <div class="tf-toggles">
          <label class="cfg check"><input type="checkbox" name="system.transform.enabled" {{checked system.transform.enabled}}/> {{localize "SHIFT.Transform.Enabled"}}</label>
          <label class="cfg check"><input type="checkbox" name="system.transform.auto" {{checked system.transform.auto}}/> {{localize "SHIFT.Transform.Auto"}}</label>
          <label class="cfg check"><input type="checkbox" name="system.transform.playerVisible" {{checked system.transform.playerVisible}}/> {{localize "SHIFT.Transform.PlayerVisible"}}</label>
          <label class="cfg tf-reset">
            <span>{{localize "SHIFT.Transform.ResetDie"}}</span>
            <select name="system.transform.resetDie">
              {{#each diceList}}<option value="{{this}}" {{#if (shiftEq this @root.system.transform.resetDie)}}selected{{/if}}>{{shiftDieLabel this}}</option>{{/each}}
            </select>
          </label>
        </div>
        <p class="tf-hint">{{localize "SHIFT.Transform.ResetHint"}}</p>
      {{/if}}

      <ol class="tf-forms">
        {{!-- BASE: a identidade própria do Trait. O snapshot se auto-atualiza ao sair dela. --}}
        <li class="tf-form base{{#if transformAtBase}} current{{/if}}">
          <span class="tf-stage-dot"></span>
          <span class="tf-form-name">{{localize "SHIFT.Transform.BaseForm"}}</span>
          {{#if transformAtBase}}
            <span class="tf-current-tag">{{localize "SHIFT.Transform.Current"}}</span>
          {{else}}
            {{#if transformBase.captured}}<span class="tf-form-snap">{{transformBase.name}}{{#if transformBase.die}} · {{transformBase.die}}{{/if}}</span>{{/if}}
            {{#if canViewTransform}}
              <span class="tf-form-actions">
                <a class="ta-btn" data-action="transformTo" data-stage="-1" data-tooltip="{{localize 'SHIFT.Transform.BecomeThis'}}"><i class="fa-solid fa-wand-magic-sparkles"></i></a>
              </span>
            {{/if}}
          {{/if}}
        </li>
        {{#each transformForms}}
          <li class="tf-form{{#if current}} current{{/if}}{{#if missing}} missing{{/if}}" data-form-uuid="{{uuid}}">
            <span class="tf-stage-dot"></span>
            {{#if img}}<img class="tf-form-img" src="{{img}}" alt=""/>{{/if}}
            {{#if @root.canEditTransform}}
              <a class="tf-form-name" data-action="openForm" data-tooltip="{{localize 'SHIFT.Transform.OpenForm'}}">{{name}}</a>
            {{else}}
              <span class="tf-form-name">{{name}}</span>
            {{/if}}
            {{#if die}}<span class="tf-form-die">{{die}}</span>{{/if}}
            {{#if current}}<span class="tf-current-tag">{{localize "SHIFT.Transform.Current"}}</span>{{/if}}
            {{#if @root.canViewTransform}}
              <span class="tf-form-actions">
                {{!-- Reposicionar (setas) + trocar de forma (✦): nível VER. --}}
                <a class="ta-btn{{#if first}} disabled{{/if}}" data-action="moveForm" data-index="{{index}}" data-dir="-1" data-tooltip="{{localize 'SHIFT.Common.MoveUp'}}"><i class="fa-solid fa-arrow-up"></i></a>
                <a class="ta-btn{{#if last}} disabled{{/if}}" data-action="moveForm" data-index="{{index}}" data-dir="1" data-tooltip="{{localize 'SHIFT.Common.MoveDown'}}"><i class="fa-solid fa-arrow-down"></i></a>
                {{#unless current}}<a class="ta-btn" data-action="transformTo" data-stage="{{index}}" data-tooltip="{{localize 'SHIFT.Transform.BecomeThis'}}"><i class="fa-solid fa-wand-magic-sparkles"></i></a>{{/unless}}
                {{!-- Deletar a forma: nível EDITAR (GM/Trusted+). --}}
                {{#if @root.canEditTransform}}<a class="ta-btn danger" data-action="removeForm" data-index="{{index}}" data-tooltip="{{localize 'SHIFT.Common.Remove'}}"><i class="fa-solid fa-xmark"></i></a>{{/if}}
              </span>
            {{/if}}
          </li>
        {{/each}}
      </ol>

      {{#if canEditTransform}}
        <div class="tf-add">
          <div class="tf-dropzone">{{localize "SHIFT.Transform.DropHint"}}</div>
          <button type="button" class="tf-create" data-action="createForm"><i class="fa-solid fa-plus"></i> {{localize "SHIFT.Transform.CreateForm"}}</button>
        </div>
      {{/if}}
    </section>
  </div>
  {{/if}}

  {{> "shift.item-source"}}
</div>
