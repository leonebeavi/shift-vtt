{{!-- Landmark item sheet: name, Safe/Unsafe, source and a description.
      An owner sees the lock toggle; locked shows the observer (player) view. --}}
<div class="item-sheet landmark-sheet minimal">
  <header class="item-header">
    <img class="item-img" src="{{item.img}}" alt="{{item.name}}" data-action="editImage" data-edit="img"
         data-tooltip="{{localize 'SHIFT.Tooltips.EditImage'}}"/>
    <div class="item-id">
      <input class="item-name" type="text" name="name" value="{{item.name}}" {{#unless editMode}}disabled{{/unless}}/>
      <div class="item-subline">
        {{#if editable}}
          <a class="item-lock{{#if editMode}} active{{/if}}" data-action="toggleEdit">
            <i class="fa-solid {{#if editMode}}fa-lock-open{{else}}fa-lock{{/if}}"></i>
          </a>
        {{/if}}
        <label class="recharge-pill landmark-safe-toggle{{#if system.safe}} on{{/if}}">
          <input type="checkbox" name="system.safe" {{checked system.safe}} {{#unless editMode}}disabled{{/unless}}/>
          <span><i class="fa-solid {{#if system.safe}}fa-campground{{else}}fa-fire{{/if}}"></i>
            {{#if system.safe}}{{localize "SHIFT.Location.Safe"}}{{else}}{{localize "SHIFT.Location.Unsafe"}}{{/if}}</span>
        </label>
      </div>
    </div>
  </header>

  {{#if (shiftOr enrichedDescription editMode)}}
    <section class="item-description">
      {{#if editMode}}
        <prose-mirror name="system.description" value="{{source.description}}" toggled
                      document-uuid="{{item.uuid}}" class="bio-prose">
          {{{enrichedDescription}}}
        </prose-mirror>
      {{else}}
        <div class="bio-display">{{{enrichedDescription}}}</div>
      {{/if}}
    </section>
  {{/if}}

  {{> "shift.item-gmnote"}}

  {{> "shift.item-source"}}
</div>
