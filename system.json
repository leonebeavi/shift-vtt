{
  "id": "shift-vtt",
  "title": "SHIFT VTT",
  "description": "An unofficial Foundry VTT implementation of the SHIFT Roleplaying Game.",
  "version": "2.4.0",
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "authors": [
    {
      "name": "Leone"
    }
  ],
  "media": [
    {
      "type": "cover",
      "url": "systems/shift-vtt/assets/misc/shift-vtt-banner.webp"
    },
    {
      "type": "setup",
      "url": "systems/shift-vtt/assets/misc/shift-vtt-banner.webp",
      "thumbnail": "systems/shift-vtt/assets/misc/shift-vtt-banner.webp"
    }
  ],
  "esmodules": [
    "shift.mjs"
  ],
  "styles": [
    "styles/shift.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "pt-BR",
      "name": "Português (Brasil)",
      "path": "lang/pt-BR.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": [
          "description"
        ]
      },
      "adversary": {
        "htmlFields": [
          "description"
        ]
      },
      "vehicle": {
        "htmlFields": [
          "description"
        ]
      },
      "location": {
        "htmlFields": [
          "description"
        ]
      },
      "party": {
        "htmlFields": [
          "description"
        ]
      }
    },
    "Item": {
      "trait": {
        "htmlFields": [
          "description"
        ]
      },
      "keyword": {
        "htmlFields": [
          "description"
        ]
      },
      "drawback": {
        "htmlFields": [
          "description"
        ]
      },
      "technique": {
        "htmlFields": [
          "description"
        ]
      },
      "landmark": {
        "htmlFields": [
          "description"
        ]
      },
      "quest": {
        "htmlFields": [
          "description"
        ]
      }
    }
  },
  "packs": [
    {
      "name": "shift-traits",
      "label": "Items | SHIFT",
      "path": "packs/shift-traits",
      "type": "Item",
      "system": "shift-vtt",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "shift-macros",
      "label": "Macros | SHIFT",
      "path": "packs/shift-macros",
      "type": "Macro",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "socket": true,
  "grid": {
    "distance": 5,
    "units": "ft"
  },
  "url": "https://github.com/leonebeavi/shift-vtt",
  "manifest": "https://github.com/leonebeavi/shift-vtt/releases/latest/download/system.json",
  "download": "https://github.com/leonebeavi/shift-vtt/releases/download/v2.4.0/system.zip",
  "license": "LICENSE.md",
  "readme": "README.md",
  "flags": {
    "hotReload": {
      "extensions": [
        "css",
        "hbs",
        "json"
      ],
      "paths": [
        "styles/shift.css",
        "templates",
        "lang"
      ]
    }
  }
}